# Copy this file to `.env` and fill in your secrets for local runs.
# `.env` is gitignored. On GitHub Actions these come from repository Secrets.

# Gmail App Password (16 chars, spaces optional) — NOT your normal password.
GMAIL_APP_PASSWORD=

# Optional, only if you enable the WhatsApp channel later.
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=
